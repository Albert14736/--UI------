<?xml version="1.0" encoding="utf-8"?>
<Context>
    <!-- 使用 Size="...,Auto" 让容器根据内容自动撑开高度 -->
    <!-- 使用 Texture="Controls_DropdownPanel" 保持与原版风格一致 -->
    <!-- 宽度调整为 296，像素级最终对齐 -->
    <Grid ID="HonkaiTrackerGrid" Size="296,Auto" AutoSizePadding="0,5" Texture="Controls_DropdownPanel" Color="40,40,40,200" Anchor="L,T" Hidden="0">
        
        <!-- 内部容器 -->
        <Stack ID="HonkaiResourceStack" Anchor="L,T" Offset="15,5" StackGrowth="Down" StackPadding="4">
            
            <!-- 第一行：崩坏研究点 -->
            <Label ID="HonkaiResearchLabel" String="0" Style="FontNormal14" ColorSet="COLORSET_HONKAI_RESEARCH" />
            
            <!-- 第二行：战术崩坏能 -->
            <Label ID="HonkaiEnergyLabel" String="0" Style="FontNormal14" ColorSet="COLORSET_HONKAI_ENERGY" />
            
        </Stack>

        <!-- 装饰底线，调低透明度 -->
        <Box ID="BottomLine" Color="255,255,255,20" Anchor="L,B" Size="parent,1" Offset="0,0" />
        
    </Grid>
</Context>
