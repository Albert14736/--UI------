<?xml version="1.0" encoding="utf-8"?>
<Mod id="5a8134cb-72e9-4bd4-8fc2-dcbe7891d18a" version="1">
  <Properties>
    <Name>LOC_HONKAI_UI_TEST_NAME</Name>
    <Description>崩坏里世界：独立UI指挥终端测试模组</Description>
    <Authors>Albert</Authors>
    <CompatibleVersions>1.2,2.0</CompatibleVersions>
  </Properties>

  <Dependencies>
    <Mod id="4873eb62-8ccc-4574-b784-dda455e74e68" title="Expansion: Gathering Storm" />
    <Mod id="1B28771A-C749-434B-9053-D1380C553DE9" title="Expansion: Rise and Fall" />
  </Dependencies>

  <LocalizedText>
    <Text id="LOC_HONKAI_UI_TEST_NAME">
      <zh_Hans_CN>崩坏指挥终端 (独立UI测试)</zh_Hans_CN>
    </Text>
  </LocalizedText>

  <FrontEndActions>
