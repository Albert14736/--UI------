<?xml version="1.0" encoding="utf-8"?>
<GameData>
    <LocalizedText>
        <!-- ========================================================== -->
        <!-- 简体中文 (zh_Hans_CN) -->
        <!-- ========================================================== -->
        <Row Tag="LOC_HONKAI_TECH_PERCEPTION_NAME" Language="zh_Hans_CN">
            <Text>崩坏能感知</Text>
        </Row>
        <Row Tag="LOC_HONKAI_TECH_PERCEPTION_DESC" Language="zh_Hans_CN">
            <Text>消耗 {1_Amount} [ICON_Faith] 崩坏能[NEWLINE][NEWLINE]一切的开始。允许开采崩坏能矿脉，并揭示基础的崩坏现象。</Text>
        </Row>
        <Row Tag="LOC_HONKAI_TECH_OMEN_NAME" Language="zh_Hans_CN"><Text>崩坏预兆</Text></Row>
        <Row Tag="LOC_HONKAI_TECH_OMEN_DESC" Language="zh_Hans_CN"><Text>消耗 {1_Amount} [ICON_Faith] 崩坏能[NEWLINE][NEWLINE]每回合无条件 +1 信仰值。（极速抢发万神殿）</Text></Row>
        
        <Row Tag="LOC_HONKAI_TECH_PATHOLOGY_NAME" Language="zh_Hans_CN"><Text>崩坏病理学</Text></Row>
        <Row Tag="LOC_HONKAI_TECH_PATHOLOGY_DESC" Language="zh_Hans_CN"><Text>消耗 {1_Amount} [ICON_Faith] 崩坏能[NEWLINE][NEWLINE]城市免疫部分崩坏灾难导致的宜居度惩罚。</Text></Row>
        
        <Row Tag="LOC_HONKAI_TECH_BASIC_TACTICS_NAME" Language="zh_Hans_CN"><Text>基础抗崩坏战术</Text></Row>
        <Row Tag="LOC_HONKAI_TECH_BASIC_TACTICS_DESC" Language="zh_Hans_CN"><Text>消耗 {1_Amount} [ICON_Faith] 崩坏能[NEWLINE][NEWLINE]近战单位对野蛮人获得战力加成。</Text></Row>
        
        <Row Tag="LOC_HONKAI_TECH_ENERGY_CONTAINER_NAME" Language="zh_Hans_CN"><Text>能源容器雏形</Text></Row>
        <Row Tag="LOC_HONKAI_TECH_ENERGY_CONTAINER_DESC" Language="zh_Hans_CN"><Text>消耗 {1_Amount} [ICON_Faith] 崩坏能[NEWLINE][NEWLINE]解锁初级【崩坏能存储池】建筑。</Text></Row>
        
        <Row Tag="LOC_HONKAI_TECH_DESTINY_CLERGY_NAME" Language="zh_Hans_CN"><Text>命运神职</Text></Row>
        <Row Tag="LOC_HONKAI_TECH_DESTINY_CLERGY_DESC" Language="zh_Hans_CN"><Text>消耗 {1_Amount} [ICON_Faith] 崩坏能[NEWLINE][NEWLINE]每回合无条件 +2 大预言家点数。</Text></Row>
        
        <Row Tag="LOC_HONKAI_TECH_NUN_FORMATION_NAME" Language="zh_Hans_CN"><Text>天命修女编制</Text></Row>
        <Row Tag="LOC_HONKAI_TECH_NUN_FORMATION_DESC" Language="zh_Hans_CN"><Text>消耗 {1_Amount} [ICON_Faith] 崩坏能[NEWLINE][NEWLINE]信仰值购买单位费用降低 10%。</Text></Row>
        
        <Row Tag="LOC_HONKAI_TECH_BASIC_ISOLATION_NAME" Language="zh_Hans_CN"><Text>初级崩坏隔离</Text></Row>
        <Row Tag="LOC_HONKAI_TECH_BASIC_ISOLATION_DESC" Language="zh_Hans_CN"><Text>消耗 {1_Amount} [ICON_Faith] 崩坏能[NEWLINE][NEWLINE]建筑抗灾能力提升。</Text></Row>
        
        <Row Tag="LOC_HONKAI_TECH_ST_FREYA_NAME" Language="zh_Hans_CN">
            <Text>圣芙蕾雅学园</Text>
        </Row>
        <Row Tag="LOC_HONKAI_TECH_ST_FREYA_DESC" Language="zh_Hans_CN">
            <Text>消耗 {1_Amount} [ICON_Faith] 崩坏能[NEWLINE][NEWLINE]解锁特色建筑【圣芙蕾雅学园】（所在城市局部女武神训练等级大幅提升）。</Text>
        </Row>
        
        <Row Tag="LOC_HONKAI_TECH_WEAPON_PROTOTYPE_NAME" Language="zh_Hans_CN"><Text>崩坏能武器初设</Text></Row>
        <Row Tag="LOC_HONKAI_TECH_WEAPON_PROTOTYPE_DESC" Language="zh_Hans_CN"><Text>消耗 {1_Amount} [ICON_Faith] 崩坏能[NEWLINE][NEWLINE]解锁 T1 B级女武神。</Text></Row>

        <!-- 古典时代 -->
        <Row Tag="LOC_HONKAI_TECH_STIGMATA_PROTOTYPE_NAME" Language="zh_Hans_CN"><Text>人工圣痕雏形</Text></Row>
        <Row Tag="LOC_HONKAI_TECH_STIGMATA_PROTOTYPE_DESC" Language="zh_Hans_CN"><Text>消耗 {1_Amount} [ICON_Faith] 崩坏能[NEWLINE][NEWLINE]解锁【基因实验室】建筑。</Text></Row>
        <Row Tag="LOC_HONKAI_TECH_HONKAI_FURNACE_NAME" Language="zh_Hans_CN"><Text>崩坏能熔炉</Text></Row>
        <Row Tag="LOC_HONKAI_TECH_HONKAI_FURNACE_DESC" Language="zh_Hans_CN"><Text>消耗 {1_Amount} [ICON_Faith] 崩坏能[NEWLINE][NEWLINE]解锁城市项目【崩坏能转化】。</Text></Row>
        <Row Tag="LOC_HONKAI_TECH_SCHICKSAL_DOCTRINE_NAME" Language="zh_Hans_CN"><Text>天命教义</Text></Row>
        <Row Tag="LOC_HONKAI_TECH_SCHICKSAL_DOCTRINE_DESC" Language="zh_Hans_CN"><Text>消耗 {1_Amount} [ICON_Faith] 崩坏能[NEWLINE][NEWLINE]圣地相邻加成提升。</Text></Row>
        <Row Tag="LOC_HONKAI_TECH_PRAYER_ROOM_NAME" Language="zh_Hans_CN"><Text>祈祷室基建</Text></Row>
        <Row Tag="LOC_HONKAI_TECH_PRAYER_ROOM_DESC" Language="zh_Hans_CN"><Text>消耗 {1_Amount} [ICON_Faith] 崩坏能[NEWLINE][NEWLINE]解锁专属信仰建筑，提供科研。</Text></Row>
        <Row Tag="LOC_HONKAI_TECH_HONKAI_CONDUCTION_NAME" Language="zh_Hans_CN"><Text>崩坏能传导</Text></Row>
        <Row Tag="LOC_HONKAI_TECH_HONKAI_CONDUCTION_DESC" Language="zh_Hans_CN"><Text>消耗 {1_Amount} [ICON_Faith] 崩坏能[NEWLINE][NEWLINE]连接的城市提供额外产出。</Text></Row>
        <Row Tag="LOC_HONKAI_TECH_ATONEMENT_SYSTEM_NAME" Language="zh_Hans_CN"><Text>赎罪体系</Text></Row>
        <Row Tag="LOC_HONKAI_TECH_ATONEMENT_SYSTEM_DESC" Language="zh_Hans_CN"><Text>消耗 {1_Amount} [ICON_Faith] 崩坏能[NEWLINE][NEWLINE]驻扎女武神提供信仰和文化。</Text></Row>
        <Row Tag="LOC_HONKAI_TECH_KNIGHT_LEGACY_NAME" Language="zh_Hans_CN"><Text>骑士传承</Text></Row>
        <Row Tag="LOC_HONKAI_TECH_KNIGHT_LEGACY_DESC" Language="zh_Hans_CN"><Text>消耗 {1_Amount} [ICON_Faith] 崩坏能[NEWLINE][NEWLINE]天命特色防御建筑加成。</Text></Row>
        <Row Tag="LOC_HONKAI_TECH_POWER_ARMOR_NAME" Language="zh_Hans_CN"><Text>动力装甲原理</Text></Row>
        <Row Tag="LOC_HONKAI_TECH_POWER_ARMOR_DESC" Language="zh_Hans_CN"><Text>消耗 {1_Amount} [ICON_Faith] 崩坏能[NEWLINE][NEWLINE]减少特色单位维护费。</Text></Row>
        <Row Tag="LOC_HONKAI_TECH_VALKYRIE_ADVANCED_NAME" Language="zh_Hans_CN"><Text>女武神进阶教材</Text></Row>
        <Row Tag="LOC_HONKAI_TECH_VALKYRIE_ADVANCED_DESC" Language="zh_Hans_CN"><Text>消耗 {1_Amount} [ICON_Faith] 崩坏能[NEWLINE][NEWLINE]帝国全局【女武神训练等级】+1。</Text></Row>

